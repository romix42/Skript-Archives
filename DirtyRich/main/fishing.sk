options:
	prefix: <##ffff28>&lDIRTYRICH &8| &f
	c1: <##ffff28>
	c2: <##ffff74>

	error: <##fd7474>❌ ᴇʀʀᴏʀ: <##ff6060>
	error2: <##ff6060>
	success: <##74fd7b>✔ ꜱᴜᴄᴄᴇꜱꜱ: <##92ff60>
	success2: <##92ff60>

	col-common: <##d8d8d8>
	col-uncommon: <##7bff7b>
	col-rare: <##82a9ff>
	col-epic: <##ff94ff>
	col-legendary: <##ffd04f>
	col-mythic: <##ff6f6f>

	max-luck: 50
	max-speed: 50
	max-greed: 50

on load:
	fish_initRarities()
	fish_initFish()


function fish_initRarities():
	#               id           display   weight  mult  minKg  maxKg   color
	addFishRarity("common",    "COMMON",    600,  1.0,   0.1,   2.0,  "{@col-common}")
	addFishRarity("uncommon",  "UNCOMMON",  250,  2.2,   0.5,   6.0,  "{@col-uncommon}")
	addFishRarity("rare",      "RARE",      100,  6.0,   1.5,  15.0,  "{@col-rare}")
	addFishRarity("epic",      "EPIC",       40, 16.0,   4.0,  30.0,  "{@col-epic}")
	addFishRarity("legendary", "LEGENDARY",   8, 45.0,  10.0,  65.0,  "{@col-legendary}")
	addFishRarity("mythic",    "MYTHIC",      2, 130.0, 20.0, 110.0,  "{@col-mythic}")

